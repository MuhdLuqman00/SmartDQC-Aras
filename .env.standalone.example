# Copy this file to ".env" (same folder as docker-compose.standalone.yml),
# then change OLLAMA_MODEL to test a different LLM. Re-run:
#
#   docker compose -f docker-compose.standalone.yml up -d
#
# Compose auto-loads ".env", so no other flags are needed.

# Any valid Ollama model tag — see https://ollama.com/library
# Examples:
#   llama3.1:8b-instruct-q3_K_M   (default, smaller/faster)
#   llama3.1:8b
#   qwen2.5:7b-instruct
#   mistral:7b
#   gemma2:9b
OLLAMA_MODEL=llama3.1:8b-instruct-q3_K_M

# How long Ollama keeps the model loaded in memory between requests.
# "30m" = 30 minutes, "-1" = keep loaded forever (avoids post-idle slowness).
OLLAMA_KEEP_ALIVE=30m
