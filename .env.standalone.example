# Copy this file to ".env" (same folder as docker-compose.standalone.yml),
# then change OLLAMA_MODEL to test a different LLM. Re-run:
#
#   docker compose -f docker-compose.standalone.yml up -d
#
# Compose auto-loads ".env", so no other flags are needed.

# Any valid Ollama model tag (https://ollama.com/library) or an
# hf.co/<repo>:<quant> GGUF reference.
# Examples:
#   hf.co/mradermacher/gemma-4-E4B-GGUF:Q6_K     (default; needs >8GB VRAM)
#   hf.co/mradermacher/gemma-4-E4B-GGUF:Q4_K_M   (~5.4GB, fits 8GB GPU)
#   hf.co/mradermacher/gemma-4-E2B-GGUF:Q8_0     (~5.1GB, smaller/faster)
#   llama3.1:8b-instruct-q3_K_M
OLLAMA_MODEL=hf.co/mradermacher/gemma-4-E4B-GGUF:Q6_K

# How long Ollama keeps the model loaded in memory between requests.
# "30m" = 30 minutes, "-1" = keep loaded forever (avoids post-idle slowness).
OLLAMA_KEEP_ALIVE=30m

# ── Authentication — REQUIRED, change both before any deployment ─────────────
# Generate JWT_SECRET with: openssl rand -hex 32
JWT_SECRET=change-me-before-production
ADMIN_SEED_PASSWORD=change-me-before-production
